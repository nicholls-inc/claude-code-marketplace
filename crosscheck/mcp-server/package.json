{
  "name": "crosscheck-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Dafny crosscheck verification",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && tsc --noEmit && esbuild src/index.ts --bundle --platform=node --target=es2022 --format=esm --outfile=dist/index.js",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "vitest run --exclude 'src/__tests__/e2e/**'",
    "test:watch": "vitest --exclude 'src/__tests__/e2e/**'",
    "test:e2e": "vitest run --include 'src/__tests__/e2e/**'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.15.0",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "fast-check": "^4.1.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^3.1.1"
  }
}
